{
  "model_version": "claude-sonnet-4-6",
  "test_reports_glob": "reports/test-results.xml",
  "test_command": ["pytest", "--junitxml=reports/test-results.xml", "-v"],
  "cleanup_directories": ["reports"],
  "max_retries": 10,
  "compilation_error_identifier": "Python Syntax/Import Error",
  "fallback_exception_regex": "([A-Z][a-zA-Z]*(?:Error|Exception))"
}